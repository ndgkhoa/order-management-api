{
  // Broad config: the editor, ESLint and `tsc --noEmit` all use this so EVERY file
  // (src + test) resolves with the same options + path aliases. Emit settings live in
  // tsconfig.build.json so the build never compiles tests into dist.
  "compilerOptions": {
    "target": "ES2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ES2023"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": true,
    // No `baseUrl` (deprecated in TS 6.0, removed in TS 7.0). With `paths` and no baseUrl,
    // TS resolves targets relative to this config's directory, so every target is an
    // explicit `./`-relative path. tsc typechecks, tsx (dev) and Vitest (test) resolve these
    // at runtime, and esbuild rewrites them at build (replacing tsc-alias, which needed baseUrl).
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./src/config/*"],
      "@infra/*": ["./src/infra/*"],
      "@modules/*": ["./src/modules/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@test/*": ["./test/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
