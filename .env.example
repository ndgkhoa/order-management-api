# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=orders
DATABASE_URL=

# RabbitMQ
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_URL=

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=15m

# Payment webhook
WEBHOOK_HMAC_SECRET=
MOCK_PAYMENT_DELAY_MS=2000
PAYMENT_WEBHOOK_URL=http://localhost:3000/webhooks/payment
WEBHOOK_TIMESTAMP_SKEW_MS=300000

# Shipping
SHIPPING_STEP_MS=3000

# Mail
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@orders.test

# Outbox relay
OUTBOX_POLL_INTERVAL_MS=1000

# Rate limit
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# Grafana
GRAFANA_ADMIN_PASSWORD=
