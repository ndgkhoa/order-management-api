# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgres://app:app@localhost:5432/orders

# --- RabbitMQ ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- Auth ---
# JWT_SECRET must be at least 32 chars
JWT_SECRET=
JWT_EXPIRES_IN=15m

# --- Email ---
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@orders.local

# --- Outbox relay ---
OUTBOX_POLL_INTERVAL_MS=1000

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=
