# Template for `.env` (local). Copy to `.env` and fill every blank — there are NO weak defaults.
# Generate secrets:  openssl rand -hex 16   (JWT_SECRET: openssl rand -hex 32)
# Prod uses a separate `.env.prod` with its own strong values (never commit either real file).

# --- App ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=orders
DATABASE_URL=

# --- RabbitMQ ---
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_URL=

# --- Redis (idempotency store, webhook dedup, cache, rate-limit backend) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# JWT_SECRET must be at least 32 chars
JWT_SECRET=
JWT_EXPIRES_IN=15m

# --- Webhook / mock payment provider (phase 6) ---
# WEBHOOK_HMAC_SECRET must be at least 32 chars (openssl rand -hex 32)
WEBHOOK_HMAC_SECRET=
MOCK_PAYMENT_DELAY_MS=2000
PAYMENT_WEBHOOK_URL=http://localhost:3000/webhooks/payment
WEBHOOK_TIMESTAMP_SKEW_MS=300000

# --- Shipping (phase 7: fake shipping worker) ---
SHIPPING_STEP_MS=3000

# --- Email (local: mailpit) ---
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=no-reply@orders.local

# --- Outbox relay ---
OUTBOX_POLL_INTERVAL_MS=1000

# --- Rate limit (Redis-backed, shared across instances) ---
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=1 minute

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SENTRY_DSN=

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=
